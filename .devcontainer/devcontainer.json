// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
  // General devcontainer.json properties
  "name": "libxslt",
  "containerEnv": { "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0" },
  "containerUser": "ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      // Otherwise, defaults to lts
      "version": "26.5.0",
      "pnpmVersion": "none",
      /**
       * Otherwise, it attempts to use corepack from
       * /emsdk/node/22.16.0_64bit/bin/corepack, resulting in error:
       * EACCES: permission denied, symlink
       * '../lib/node_modules/corepack/dist/pnpm.js' ->
       * '/emsdk/node/22.16.0_64bit/bin/pnpm'
       */
      "installYarnUsingApt": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools",
        "vitest.explorer"
      ]
    }
  },

  // Image or Dockerfile specific properties
  "build": { "context": "..", "dockerfile": "./Dockerfile" },

  // Lifecycle scripts
  "postCreateCommand": ".devcontainer/post-create.sh"
}
